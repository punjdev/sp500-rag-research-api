# Version control
.git/
.gitignore

# Environment / secrets
.env
.env.*

# Python caches (rebuilt in container)
__pycache__/
*.pyc
*.pyo

# Virtual environment (not used in Docker; deps installed system-wide)
.venv/
venv/

# BM25 pickles (rebuilt at startup from Qdrant)
data/bm25_index.pkl
data/bm25_chunks.pkl

# Raw EDGAR data (not needed at runtime)
data/raw/

# Ingestion checkpoint
data/checkpoints/

# Benchmark results
data/benchmark_results/

# Logs
logs/

# Dev / docs only
claude-reference.md
.DS_Store
.idea/
.vscode/
